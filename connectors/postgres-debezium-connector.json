{
  "name": "iot-postgres-connector",
  "config": {
    "connector.class": "io.debezium.connector.postgresql.PostgresConnector",
    "database.hostname": "postgres",
    "database.port": "5432",
    "database.user": "iot_app",
    "database.password": "iot_app_password",
    "database.dbname": "iot_operational",
    "topic.prefix": "iot",
    "plugin.name": "pgoutput",
    "publication.name": "iot_publication",
    "slot.name": "iot_debezium_slot",
    "table.include.list": "public.devices,public.telemetry,public.alerts",
    "snapshot.mode": "initial",
    "tombstones.on.delete": "false"
  }
}
