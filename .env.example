# Postgres (operational OLTP database)
POSTGRES_DB=iot_operational
POSTGRES_USER=iot_app
POSTGRES_PASSWORD=iot_app_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONNECT_URL=http://localhost:8083

# Redis (dashboard response cache)
REDIS_URL=redis://localhost:6379/1
DASHBOARD_CACHE_TTL_SECONDS=60

# Snowflake (analytics OLAP database)
# Leave blank to use the built-in mock client for local development.
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=

# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_LOG_LEVEL=INFO
